{
  "DataSourceMode": "Demo",
  "XPlane12ApiBaseUrl": "http://localhost:8086/",
  "EnableWebServer": true,
  "EnableWebServerLanAccess": true,
  "EnableVatsimCallsignLookup": true,
  "VatsimDataFeedUrl": "https://data.vatsim.net/v3/vatsim-data.json",
  "VatsimCallsignRefreshSeconds": 15,
  "EnableDataSourceDebugLogging": false,
  "MinTrackedAltitudeFt": 200,
  "RangeScaleOptionsNm": [10, 20, 40, 80, 120],
  "SelectedRangeNm": 40,
  "OrientationMode": 1,
  "DirectionReferenceMode": 0,
  "ShowMapLayer": true,
  "MapOpacity": 0.65,
  "MapLabelBackgroundOpacity": 0.75,
  "ShowRangeRings": true,
  "TargetSymbolScale": 1.0,
  "ShowAirspaceBoundaries": true,
  "ShowControlledAirspaceLayer": false,
  "ShowOnlyActiveAirspaceBoundaries": true,
  "AirspaceOpacity": 1.0,
  "AirspaceFirCode": "efin",
  "AirspaceDataBaseUrl": "https://raw.githubusercontent.com/ottotuhkunen/virtual-lara-airspace-data/main/data",
  "AirspaceActivationUrl": "https://lara-backend.lusep.fi/data/reservations/efin.json",
  "ShowBullseye": false,
  "BullseyeLatitudeDeg": null,
  "BullseyeLongitudeDeg": null,
  "Declutter": false,
  "TrailsEnabled": true,
  "LabelMode": 1,
  "CategoryFilter": 0,
  "TrailLengthSamples": 90,
  "PollRateHz": 8,
  "RenderRateFps": 24,
  "StaleSeconds": 4,
  "RemoveAfterSeconds": 12,
  "Hotkeys": [
    { "Action": "range-up", "Keyboard": "", "Gamepad": "DPadUp", "IsEnabled": true },
    { "Action": "range-down", "Keyboard": "", "Gamepad": "DPadDown", "IsEnabled": true },
    { "Action": "orientation", "Keyboard": "", "Gamepad": "Y", "IsEnabled": true },
    { "Action": "map", "Keyboard": "", "Gamepad": "", "IsEnabled": true },
    { "Action": "declutter", "Keyboard": "Ctrl+D", "Gamepad": "X", "IsEnabled": true },
    { "Action": "trails", "Keyboard": "", "Gamepad": "", "IsEnabled": true },
    { "Action": "bullseye", "Keyboard": "", "Gamepad": "", "IsEnabled": true },
    { "Action": "intercept", "Keyboard": "", "Gamepad": "A", "IsEnabled": true },
    { "Action": "labels", "Keyboard": "", "Gamepad": "B", "IsEnabled": true },
    { "Action": "airspace", "Keyboard": "", "Gamepad": "", "IsEnabled": true },
    { "Action": "area", "Keyboard": "", "Gamepad": "", "IsEnabled": true },
    { "Action": "pin", "Keyboard": "Ctrl+T", "Gamepad": "", "IsEnabled": true },
    { "Action": "settings", "Keyboard": "Ctrl+H", "Gamepad": "Start", "IsEnabled": true },
    { "Action": "kneepad", "Keyboard": "Ctrl+K", "Gamepad": "Back", "IsEnabled": true },
    { "Action": "kneepad-prev", "Keyboard": "Ctrl+PageUp", "Gamepad": "LeftShoulder", "IsEnabled": true },
    { "Action": "kneepad-next", "Keyboard": "Ctrl+PageDown", "Gamepad": "RightShoulder", "IsEnabled": true }
  ]
}
