<Window x:Class="TacticalDisplay.App.HotkeyConfigDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configure Hotkeys"
        Width="720"
        Height="620"
        MinWidth="640"
        MinHeight="480"
        Background="#071015"
        WindowStartupLocation="CenterOwner"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Press SET, then press the keyboard shortcut, XInput gamepad button, or flight joystick button. Esc cancels; Delete or Backspace clears the selected binding."
                   Foreground="#7CB9A9"
                   TextWrapping="Wrap"
                   Margin="0,0,0,10" />

        <Border Grid.Row="1"
                BorderBrush="#355A56"
                BorderThickness="1"
                Background="#102028"
                Padding="8">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding HotkeyRows}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="58" />
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="58" />
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0"
                                          IsChecked="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding DisplayName}"
                                           Foreground="#9AFAD7"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"
                                           Margin="0,0,8,0" />
                                <TextBlock Grid.Column="2"
                                           Text="{Binding KeyboardDisplay}"
                                           Foreground="#D9F2EC"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding KeyboardDisplay}"
                                           Margin="0,0,8,0" />
                                <Button Grid.Column="3"
                                        Content="SET"
                                        Tag="{Binding}"
                                        Click="OnSetKeyboardHotkeyClick"
                                        Margin="0,0,8,0" />
                                <TextBlock Grid.Column="4"
                                           Text="{Binding GamepadDisplay}"
                                           Foreground="#D9F2EC"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding GamepadDisplay}"
                                           Margin="0,0,8,0" />
                                <Button Grid.Column="5"
                                        Content="SET"
                                        Tag="{Binding}"
                                        Click="OnSetGamepadHotkeyClick" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="Reset Hotkeys"
                    Command="{Binding ResetHotkeysCommand}"
                    MinWidth="110"
                    Margin="0,0,8,0" />
            <Button Content="Close"
                    Click="OnCloseClick"
                    MinWidth="90" />
        </StackPanel>
    </Grid>
</Window>
