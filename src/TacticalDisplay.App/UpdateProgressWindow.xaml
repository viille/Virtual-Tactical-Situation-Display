<Window x:Class="TacticalDisplay.App.UpdateProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Updating"
        Width="420"
        Height="150"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#071015"
        Foreground="#D9F2EC"
        ShowInTaskbar="False">
    <Border Margin="14"
            Padding="14"
            Background="#102028"
            BorderBrush="#355A56"
            BorderThickness="1"
            CornerRadius="6">
        <StackPanel>
            <TextBlock Text="Installing update"
                       FontFamily="Consolas"
                       FontSize="16"
                       FontWeight="Bold"
                       Foreground="#9AFAD7"
                       Margin="0,0,0,10" />
            <TextBlock x:Name="StatusText"
                       Text="Preparing update..."
                       FontFamily="Consolas"
                       FontSize="12"
                       Foreground="#D9F2EC"
                       Margin="0,0,0,8" />
            <ProgressBar x:Name="Progress"
                         Height="18"
                         Minimum="0"
                         Maximum="100"
                         IsIndeterminate="True" />
            <TextBlock Text="Do not close this window."
                       FontFamily="Consolas"
                       FontSize="11"
                       Foreground="#8EA5AD"
                       Margin="0,8,0,0" />
        </StackPanel>
    </Border>
</Window>
