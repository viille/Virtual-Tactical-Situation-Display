<Window x:Class="TacticalDisplay.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:TacticalDisplay.App.Controls"
        mc:Ignorable="d"
        Title="Tactical Situation Display"
        Icon="Assets/VTSD.png"
        Width="1280"
        Height="840"
        MinWidth="980"
        MinHeight="640"
        Background="#071015"
        WindowStyle="None"
        ResizeMode="CanResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      CornerRadius="0"
                      GlassFrameThickness="0"
                      ResizeBorderThickness="8"
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <Style x:Key="MfdButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42" />
            <Setter Property="MinWidth" Value="48" />
            <Setter Property="Margin" Value="4,3" />
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#D9F2EC" />
            <Setter Property="Background" Value="#283843" />
            <Setter Property="BorderBrush" Value="#617480" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="MfdSlotStyle" TargetType="Border">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="44" />
            <Setter Property="Margin" Value="5" />
            <Setter Property="Background" Value="#263742" />
            <Setter Property="BorderBrush" Value="#566976" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="MfdTickStyle" TargetType="Border">
            <Setter Property="Width" Value="5" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Margin" Value="12,8" />
            <Setter Property="Background" Value="#1A2A33" />
            <Setter Property="BorderBrush" Value="#4C6570" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="MfdSideTickStyle" TargetType="Border">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="6" />
            <Setter Property="Margin" Value="4,3" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Background" Value="#27414B" />
            <Setter Property="BorderBrush" Value="#6F8792" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="MfdArrowButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="18" />
            <Setter Property="Margin" Value="2,1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#D9F2EC" />
            <Setter Property="Background" Value="#283843" />
            <Setter Property="BorderBrush" Value="#617480" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="MfdWindowButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Margin" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#D9F2EC" />
            <Setter Property="Background" Value="#24343E" />
            <Setter Property="BorderBrush" Value="#5F747F" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <TextBlock Text="{TemplateBinding Content}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       TextAlignment="Center"
                                       FontFamily="{TemplateBinding FontFamily}"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       Foreground="{TemplateBinding Foreground}"
                                       LineHeight="{TemplateBinding FontSize}"
                                       LineStackingStrategy="BlockLineHeight"
                                       SnapsToDevicePixels="True" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="MfdToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Height" Value="42" />
            <Setter Property="MinWidth" Value="48" />
            <Setter Property="Margin" Value="4,3" />
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#D9F2EC" />
            <Setter Property="Background" Value="#283843" />
            <Setter Property="BorderBrush" Value="#617480" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="False" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#294F48" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#9AFAD7" />
                                <Setter TargetName="Chrome" Property="BorderThickness" Value="2" />
                                <Setter Property="Foreground" Value="#E9FFF8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Window.InputBindings>
        <KeyBinding Modifiers="Control"
                    Key="H"
                    Command="{Binding ToggleSettingsCommand}" />
        <KeyBinding Modifiers="Control"
                    Key="D"
                    Command="{Binding ToggleDeclutterCommand}" />
        <KeyBinding Modifiers="Control"
                    Key="T"
                    Command="{Binding ToggleAlwaysOnTopCommand}" />
    </Window.InputBindings>
    <Grid Margin="4">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="ScopeColumn" Width="3*" />
            <ColumnDefinition x:Name="SettingsColumn" Width="1.2*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border x:Name="ScopeBorder"
                Grid.Row="0"
                Grid.RowSpan="3"
                Grid.Column="0"
                Margin="0,0,10,0"
                Background="Transparent"
                BorderThickness="0">
            <Border x:Name="MfdFrame"
                    Padding="16"
                    Background="Transparent"
                    BorderBrush="#3D5360"
                    BorderThickness="2"
                    CornerRadius="8"
                    MouseLeftButtonDown="OnWindowMouseLeftButtonDown">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="54" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="78" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="68" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="92" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0"
                                Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <Button Content="N/HDG" Command="{Binding ToggleOrientationCommand}" Style="{StaticResource MfdButtonStyle}" />
                        <Border Style="{StaticResource MfdTickStyle}" />
                        <StackPanel VerticalAlignment="Center" Margin="10,0">
                            <Button Content="&#x2191;" Command="{Binding IncreaseMapOpacityCommand}" Style="{StaticResource MfdArrowButtonStyle}" />
                            <Button Content="&#x2193;" Command="{Binding DecreaseMapOpacityCommand}" Style="{StaticResource MfdArrowButtonStyle}" />
                        </StackPanel>
                        <Border Style="{StaticResource MfdTickStyle}" />
                        <ToggleButton Content="MAP" Command="{Binding ToggleMapCommand}" IsChecked="{Binding Settings.ShowMapLayer, Mode=OneWay}" Style="{StaticResource MfdToggleButtonStyle}" />
                    </StackPanel>
                    <StackPanel Grid.Row="0"
                                Grid.Column="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button Content="?"
                                Click="OnHelpButtonClick"
                                WindowChrome.IsHitTestVisibleInChrome="True"
                                Style="{StaticResource MfdWindowButtonStyle}" />
                        <Button Content="-"
                                Click="OnMinimizeButtonClick"
                                WindowChrome.IsHitTestVisibleInChrome="True"
                                Style="{StaticResource MfdWindowButtonStyle}" />
                        <Button Content="X"
                                Click="OnCloseButtonClick"
                                WindowChrome.IsHitTestVisibleInChrome="True"
                                Style="{StaticResource MfdWindowButtonStyle}" />
                    </StackPanel>
                    <Grid Grid.Row="2" Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="50" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Top">
                            <Button Content="LBL" Command="{Binding ToggleLabelsCommand}" Style="{StaticResource MfdButtonStyle}" />
                            <Border Style="{StaticResource MfdTickStyle}" />
                            <StackPanel VerticalAlignment="Center" Margin="10,0">
                                <Button Content="&#x2191;" Command="{Binding IncreaseMapOverlayOpacityCommand}" Style="{StaticResource MfdArrowButtonStyle}" />
                                <Button Content="&#x2193;" Command="{Binding DecreaseMapOverlayOpacityCommand}" Style="{StaticResource MfdArrowButtonStyle}" />
                            </StackPanel>
                            <Border Style="{StaticResource MfdTickStyle}" />
                            <ToggleButton Content="SET" Command="{Binding ToggleSettingsCommand}" IsChecked="{Binding ShowSettings, Mode=OneWay}" Style="{StaticResource MfdToggleButtonStyle}" />
                            <Border Style="{StaticResource MfdTickStyle}" />
                            <ToggleButton Content="WEB" IsChecked="{Binding WebServerEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MfdToggleButtonStyle}" />
                        </StackPanel>
                        <StackPanel Grid.Row="1"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Bottom"
                                    Margin="0,4,0,2">
                        <TextBlock Text="{Binding ConnectionText}"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#9AFAD7"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Margin="8,0" />
                            <TextBlock Text="{Binding TrafficText}"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#9AFAD7"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Margin="8,0" />
                            <TextBlock Text="{Binding SimulatorFooterText}"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#9AFAD7"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Margin="8,0" />
                            <TextBlock Text="{Binding WebDisplayText}"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#9AFAD7"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Margin="8,0" />
                            <TextBlock Text="{Binding AppVersionText}"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#8EA5AD"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Margin="8,0" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Row="1" Grid.Column="0" VerticalAlignment="Center">
                        <Button Content="RNG +" Command="{Binding IncreaseRangeCommand}" Style="{StaticResource MfdButtonStyle}" />
                        <Border Style="{StaticResource MfdSideTickStyle}" />
                        <Button Content="RNG -" Command="{Binding DecreaseRangeCommand}" Style="{StaticResource MfdButtonStyle}" />
                        <Border Style="{StaticResource MfdSideTickStyle}" />
                        <ToggleButton Content="DCLR" Command="{Binding ToggleDeclutterCommand}" IsChecked="{Binding Settings.Declutter, Mode=OneWay}" Style="{StaticResource MfdToggleButtonStyle}" />
                        <Border Style="{StaticResource MfdSideTickStyle}" />
                        <ToggleButton Content="TRAIL" Command="{Binding ToggleTrailsCommand}" IsChecked="{Binding Settings.TrailsEnabled, Mode=OneWay}" Style="{StaticResource MfdToggleButtonStyle}" />
                        <Border Style="{StaticResource MfdSideTickStyle}" />
                        <ToggleButton Content="APT" Command="{Binding ToggleAirportsCommand}" IsChecked="{Binding Settings.ShowAirportLayer, Mode=OneWay}" Style="{StaticResource MfdToggleButtonStyle}" />
                        <Border Style="{StaticResource MfdSideTickStyle}" />
                        <ToggleButton Content="NAV" Command="{Binding ToggleNavaidsCommand}" IsChecked="{Binding Settings.ShowNavaidLayer, Mode=OneWay}" Style="{StaticResource MfdToggleButtonStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="2" VerticalAlignment="Center">
                        <ToggleButton Content="AREA" Command="{Binding ToggleAirspaceCommand}" IsChecked="{Binding Settings.ShowAirspaceBoundaries, Mode=OneWay}" Style="{StaticResource MfdToggleButtonStyle}" />
                        <Border Style="{StaticResource MfdSideTickStyle}" />
                        <ToggleButton Content="PIN" Command="{Binding ToggleAlwaysOnTopCommand}" IsChecked="{Binding IsAlwaysOnTop, Mode=OneWay}" Style="{StaticResource MfdToggleButtonStyle}" />
                        <Border Style="{StaticResource MfdSideTickStyle}" />
                        <Button Content="SRC" Command="{Binding ApplyDataSourceCommand}" Style="{StaticResource MfdButtonStyle}" />
                        <Border Style="{StaticResource MfdSideTickStyle}" />
                        <Border Style="{StaticResource MfdSlotStyle}" />
                        <Border Style="{StaticResource MfdSideTickStyle}" />
                        <Button Content="TGT +" Command="{Binding IncreaseTargetSymbolScaleCommand}" Style="{StaticResource MfdButtonStyle}" />
                        <Border Style="{StaticResource MfdSideTickStyle}" />
                        <Button Content="TGT -" Command="{Binding DecreaseTargetSymbolScaleCommand}" Style="{StaticResource MfdButtonStyle}" />
                    </StackPanel>

                    <Border x:Name="DisplaySurface"
                            Grid.Row="1"
                            Grid.Column="1"
                            Margin="10"
                            Background="Transparent"
                            BorderBrush="#050A0D"
                            BorderThickness="3"
                            CornerRadius="6">
                        <Grid ClipToBounds="True">
                            <controls:OpenFreeMapControl x:Name="MapControl"
                                                         Picture="{Binding Picture}"
                                                         Settings="{Binding Settings}"
                                                         IsHitTestVisible="False" />
                            <controls:TacticalScopeControl x:Name="ScopeControl"
                                                           Picture="{Binding Picture}"
                                                           Settings="{Binding Settings}"
                                                           Airspaces="{Binding Airspaces}"
                                                           Airports="{Binding Airports}"
                                                           Navaids="{Binding Navaids}"
                                                           ManualTargetMetadata="{Binding ManualTargetMetadata}" />
                            <Border HorizontalAlignment="Center"
                                    VerticalAlignment="Top"
                                    Margin="0,8,0,0"
                                    Padding="8,3"
                                    Background="#B0071015"
                                    BorderBrush="#355A56"
                                    BorderThickness="1">
                                <TextBlock Text="{Binding HeaderText}"
                                           FontFamily="Consolas"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="#9AFAD7" />
                            </Border>
                            <Border x:Name="HelpOverlay"
                                    Background="#E0071015"
                                    BorderBrush="#9AFAD7"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Visibility="Collapsed"
                                    MouseLeftButtonDown="OnHelpOverlayMouseLeftButtonDown">
                                <Grid Margin="16">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0"
                                               Text="Controls"
                                               FontFamily="Consolas"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="#9AFAD7"
                                               Margin="0,0,0,8" />
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                        <StackPanel>
                                            <TextBlock FontFamily="Consolas" FontSize="12" Foreground="#D9F2EC" Text="RNG + / RNG - : Change visible range" Margin="0,0,0,4" />
                                            <TextBlock FontFamily="Consolas" FontSize="12" Foreground="#D9F2EC" Text="N/HDG : Switch north-up / heading-up" Margin="0,0,0,4" />
                                            <TextBlock FontFamily="Consolas" FontSize="12" Foreground="#D9F2EC" Text="MAP : Show or hide map layer" Margin="0,0,0,4" />
                                            <TextBlock FontFamily="Consolas" FontSize="12" Foreground="#D9F2EC" Text="DCLR : Reduce display clutter" Margin="0,0,0,4" />
                                            <TextBlock FontFamily="Consolas" FontSize="12" Foreground="#D9F2EC" Text="TRAIL : Show or hide target trails" Margin="0,0,0,4" />
                                            <TextBlock FontFamily="Consolas" FontSize="12" Foreground="#D9F2EC" Text="APT : Show or hide airport data" Margin="0,0,0,4" />
                                            <TextBlock FontFamily="Consolas" FontSize="12" Foreground="#D9F2EC" Text="NAV : Show or hide navaid data" Margin="0,0,0,4" />
                                            <TextBlock FontFamily="Consolas" FontSize="12" Foreground="#D9F2EC" Text="AREA : Show or hide active V-LARA airspace boundaries" Margin="0,0,0,4" />
                                            <TextBlock FontFamily="Consolas" FontSize="12" Foreground="#D9F2EC" Text="PIN : Toggle always-on-top" Margin="0,0,0,4" />
                                            <TextBlock FontFamily="Consolas" FontSize="12" Foreground="#D9F2EC" Text="SRC : Apply selected data source" Margin="0,0,0,4" />
                                            <TextBlock FontFamily="Consolas" FontSize="12" Foreground="#D9F2EC" Text="SET : Show or hide settings panel" Margin="0,0,0,4" />
                                            <TextBlock FontFamily="Consolas" FontSize="12" Foreground="#D9F2EC" Text="WEB : Turn tablet web server on or off" Margin="0,0,0,4" />
                                            <TextBlock FontFamily="Consolas" FontSize="12" Foreground="#D9F2EC" Text="TGT + / TGT - : Increase or decrease target symbol size" Margin="0,0,0,4" />
                                            <TextBlock FontFamily="Consolas" FontSize="12" Foreground="#D9F2EC" Text="Top arrows : Increase or decrease map opacity" Margin="0,0,0,4" />
                                            <TextBlock FontFamily="Consolas" FontSize="12" Foreground="#D9F2EC" Text="Bottom arrows : Increase or decrease airport/navaid/label background opacity" Margin="0,0,0,4" />
                                            <TextBlock FontFamily="Consolas" FontSize="12" Foreground="#D9F2EC" Text="? : Show this help" Margin="0,0,0,4" />
                                            <TextBlock FontFamily="Consolas" FontSize="12" Foreground="#D9F2EC" Text="- : Minimize" Margin="0,0,0,4" />
                                            <TextBlock FontFamily="Consolas" FontSize="12" Foreground="#D9F2EC" Text="X : Close" />
                                            <TextBlock FontFamily="Consolas" FontSize="12" Foreground="#D9F2EC" Text="" Margin="0,0,0,4" />
                                            <TextBlock FontFamily="Consolas" FontSize="12" Foreground="#D9F2EC" Text="" Margin="0,0,0,4" />
                                            <TextBlock FontFamily="Consolas" FontSize="12" Foreground="#D9F2EC" Text="LBL : Cycle label detail level" Margin="0,0,0,4" />
                                            <TextBlock FontFamily="Consolas" FontSize="12" Foreground="#D9F2EC" Text="Label example:" Margin="0,0,0,4" />
                                            <TextBlock FontFamily="Consolas" FontSize="12" Foreground="#D9F2EC" Text="A3 20.9 +35" Margin="0,0,0,4" />
                                            <TextBlock FontFamily="Consolas" FontSize="12" Foreground="#D9F2EC" Text="HOT 170 479" Margin="0,0,0,4" />
                                            <TextBlock FontFamily="Consolas" FontSize="12" Foreground="#D9F2EC" Text="( Name / Distance / Altitude difference ft )" Margin="0,0,0,4" />
                                            <TextBlock FontFamily="Consolas" FontSize="12" Foreground="#D9F2EC" Text="( Aspect / Heading / Closure kt )" Margin="0,0,0,4" />
                                        </StackPanel>
                                    </ScrollViewer>
                                    <TextBlock Grid.Row="2"
                                               Text="Click anywhere to close"
                                               FontFamily="Consolas"
                                               FontSize="11"
                                               Foreground="#8EA5AD"
                                               Margin="0,8,0,0"
                                               HorizontalAlignment="Center" />
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Border>

        <Border x:Name="SettingsBorder"
                Grid.Row="0"
                Grid.RowSpan="3"
                Grid.Column="1"
                Padding="10"
                Background="#102028"
                BorderBrush="#355A56"
                BorderThickness="1">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ShowSettings}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Settings"
                               FontFamily="Consolas"
                               Foreground="#9AFAD7"
                               FontSize="16"
                               Margin="0,0,0,8" />

                    <GroupBox Header="Display" Foreground="#9AFAD7" Margin="0,0,0,8" Padding="8">
                        <StackPanel>
                            <UniformGrid Columns="2" Rows="3">
                                <Button Content="N/HDG" Margin="4" Command="{Binding ToggleOrientationCommand}" />
                                <Button Content="{Binding DeclutterToggleText}" Margin="4" Command="{Binding ToggleDeclutterCommand}" />
                                <Button Content="Labels" Margin="4" Command="{Binding ToggleLabelsCommand}" />
                                <Button Content="{Binding TrailsToggleText}" Margin="4" Command="{Binding ToggleTrailsCommand}" />
                                <Button Content="{Binding MapToggleText}" Margin="4" Command="{Binding ToggleMapCommand}" />
                                <Button Content="{Binding AirspaceToggleText}" Margin="4" Command="{Binding ToggleAirspaceCommand}" />
                            </UniformGrid>
                            <TextBlock Text="{Binding MapOpacityText}"
                                       Foreground="#7CB9A9"
                                       Margin="4,8,4,0" />
                            <Slider Minimum="0"
                                    Maximum="100"
                                    TickFrequency="10"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding MapOpacityPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Margin="4,2,4,0" />
                            <Button Content="{Binding AirportsToggleText}"
                                    Margin="4,8,4,0"
                                    Command="{Binding ToggleAirportsCommand}" />
                            <TextBlock Text="{Binding AirportOpacityText}"
                                       Foreground="#7CB9A9"
                                       Margin="4,8,4,0" />
                            <Slider Minimum="0"
                                    Maximum="100"
                                    TickFrequency="10"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding AirportOpacityPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Margin="4,2,4,0" />
                            <TextBlock Text="{Binding AirportText}"
                                       Foreground="#7CB9A9"
                                       Margin="4,2,4,0" />
                            <Button Content="{Binding NavaidsToggleText}"
                                    Margin="4,8,4,0"
                                    Command="{Binding ToggleNavaidsCommand}" />
                            <TextBlock Text="{Binding NavaidOpacityText}"
                                       Foreground="#7CB9A9"
                                       Margin="4,8,4,0" />
                            <Slider Minimum="0"
                                    Maximum="100"
                                    TickFrequency="10"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding NavaidOpacityPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Margin="4,2,4,0" />
                            <TextBlock Text="{Binding NavaidText}"
                                       Foreground="#7CB9A9"
                                       Margin="4,2,4,0" />
                            <TextBlock Text="{Binding MapLabelBackgroundOpacityText}"
                                       Foreground="#7CB9A9"
                                       Margin="4,8,4,0" />
                            <Slider Minimum="0"
                                    Maximum="100"
                                    TickFrequency="10"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding MapLabelBackgroundOpacityPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Margin="4,2,4,0" />
                            <TextBlock Text="Minimum tracked altitude (ft)"
                                       Foreground="#7CB9A9"
                                       Margin="4,8,4,0" />
                            <TextBox Text="{Binding MinTrackedAltitudeFtText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Targets below this altitude are hidden"
                                     Margin="4,4,4,0" />
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Tablet Web" Foreground="#9AFAD7" Margin="0,0,0,8" Padding="8">
                        <StackPanel>
                            <CheckBox Content="{Binding WebServerToggleText}"
                                      IsChecked="{Binding WebServerEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Foreground="#9AFAD7" />
                            <TextBlock Text="{Binding WebDisplayText}"
                                       Foreground="#7CB9A9"
                                       TextWrapping="Wrap"
                                       Margin="0,6,0,0" />
                            <TextBlock Text="Turn this off when you do not want to expose the tablet display on the local network."
                                       Foreground="#7CB9A9"
                                       TextWrapping="Wrap"
                                       Margin="0,6,0,0" />
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Data Source" Foreground="#9AFAD7" Margin="0,0,0,8" Padding="8">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <ComboBox Width="150"
                                          ItemsSource="{Binding AvailableDataSources}"
                                          SelectedItem="{Binding SelectedDataSource}" />
                                <Button Content="Apply Source"
                                        Margin="8,0,0,0"
                                        Command="{Binding ApplyDataSourceCommand}" />
                            </StackPanel>
                            <TextBlock Text="{Binding SourceText}" Foreground="#9AFAD7" Margin="0,4,0,0" />
                            <StackPanel Margin="0,8,0,0">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ShowMsfsSettings}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="MSFS uses bundled SimConnect. If the connection fails, the app opens a diagnostic selection for MSFS exe or SimConnect DLL."
                                           Foreground="#7CB9A9"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Margin="0,8,0,0">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ShowXPlane12Settings}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="X-Plane 12 API URL" Foreground="#7CB9A9" />
                                <TextBox Text="{Binding XPlane12ApiBaseUrlText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Default: http://localhost:8086/"
                                         Margin="0,4,0,0" />
                                <TextBlock Text="Default: http://localhost:8086/"
                                           Foreground="#7CB9A9"
                                           Margin="0,2,0,0" />
                            </StackPanel>
                            <StackPanel Margin="0,8,0,0">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ShowXPlaneLegacySettings}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="Xplane Legacy uses XPUIPC from X-Plane\Resources\plugins."
                                           Foreground="#7CB9A9"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="V-LARA Airspace" Foreground="#9AFAD7" Margin="0,0,0,8" Padding="8">
                        <StackPanel>
                            <TextBlock Text="{Binding AirspaceText}" Foreground="#9AFAD7" />
                            <TextBlock Text="{Binding AirspaceOpacityText}" Foreground="#7CB9A9" Margin="0,6,0,0" />
                            <Slider Minimum="10"
                                    Maximum="100"
                                    TickFrequency="10"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding AirspaceOpacityPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Margin="0,2,0,0" />
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Bullseye" Foreground="#9AFAD7" Margin="0,0,0,8" Padding="8">
                        <StackPanel>
                            <UniformGrid Columns="2" Rows="2">
                                <Grid Margin="4">
                                    <TextBox x:Name="BullseyeLatitudeBox"
                                             Text="{Binding BullseyeLatitudeText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="Latitude, decimal degrees" />
                                    <TextBlock Text="N60.3172"
                                               Foreground="#778C8A"
                                               Margin="6,2,0,0"
                                               IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text, ElementName=BullseyeLatitudeBox}" Value="">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                                <Grid Margin="4">
                                    <TextBox x:Name="BullseyeLongitudeBox"
                                             Text="{Binding BullseyeLongitudeText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="Longitude, decimal degrees" />
                                    <TextBlock Text="E024.9633"
                                               Foreground="#778C8A"
                                               Margin="6,2,0,0"
                                               IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text, ElementName=BullseyeLongitudeBox}" Value="">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                                <Button Content="Set Bullseye"
                                        Command="{Binding ApplyBullseyeCommand}"
                                        Margin="4" />
                                <Button Content="Clear Bullseye"
                                        Command="{Binding ClearBullseyeCommand}"
                                        Margin="4" />
                            </UniformGrid>
                            <TextBlock Text="{Binding BullseyeText}" Foreground="#9AFAD7" Margin="0,4,0,0" />
                        </StackPanel>
                    </GroupBox>

                    <Button Content="Save Settings"
                            Command="{Binding SaveSettingsCommand}"
                            Margin="0,0,0,8" />

                    <Expander Header="Debug" Foreground="#7CB9A9" Margin="0,0,0,4">
                        <StackPanel Margin="0,8,0,0">
                            <CheckBox Content="Enable datasource debug log"
                                      IsChecked="{Binding DataSourceDebugLoggingEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Foreground="#9AFAD7" />
                            <Button Content="Open Debug Log Folder"
                                    Command="{Binding OpenDebugLogFolderCommand}"
                                    Margin="0,8,0,0" />
                            <TextBlock Text="Writes MSFS/XPlane feed diagnostics to %APPDATA%\VirtualTacticalSituationDisplay\logs\debug.log"
                                       Foreground="#7CB9A9"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0" />
                            <TextBlock Text="Range/alt/category filters can be edited in display.json."
                                       Foreground="#7CB9A9"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,0" />
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </ScrollViewer>
        </Border>

    </Grid>
</Window>
