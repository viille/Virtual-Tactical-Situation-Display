<Window x:Class="TacticalDisplay.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:TacticalDisplay.App.Controls"
        mc:Ignorable="d"
        Title="Tactical Situation Display"
        Icon="Assets/VTSD.png"
        Width="1280"
        Height="840"
        MinWidth="980"
        MinHeight="640"
        Background="#071015">
    <Window.InputBindings>
        <KeyBinding Modifiers="Control"
                    Key="H"
                    Command="{Binding ToggleSettingsCommand}" />
        <KeyBinding Modifiers="Control"
                    Key="D"
                    Command="{Binding ToggleDeclutterCommand}" />
        <KeyBinding Modifiers="Control"
                    Key="T"
                    Command="{Binding ToggleAlwaysOnTopCommand}" />
    </Window.InputBindings>
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="ScopeColumn" Width="3*" />
            <ColumnDefinition x:Name="SettingsColumn" Width="1.2*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Padding="10"
                Margin="0,0,0,10"
                Background="#102028"
                BorderBrush="#355A56"
                BorderThickness="1">
            <DockPanel LastChildFill="False">
                <TextBlock Text="{Binding HeaderText}"
                           FontFamily="Consolas"
                           FontSize="18"
                           Foreground="#9AFAD7"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0" />
                <TextBlock Text="SIMULATOR USE ONLY"
                           FontFamily="Consolas"
                           FontSize="14"
                           Foreground="#F7C873"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0" />
                <Button Content="{Binding SettingsToggleText}"
                        Command="{Binding ToggleSettingsCommand}"
                        Margin="0,0,8,0"
                        Padding="10,4" />
                <Button Content="{Binding TopMostToggleText}"
                        Command="{Binding ToggleAlwaysOnTopCommand}"
                        Padding="10,4" />
            </DockPanel>
        </Border>

        <Border x:Name="ScopeBorder"
                Grid.Row="1"
                Grid.Column="0"
                Margin="0,0,10,0"
                Background="#071015"
                BorderBrush="#355A56"
                BorderThickness="1">
            <Grid>
                <controls:OpenFreeMapControl x:Name="MapControl"
                                             Picture="{Binding Picture}"
                                             Settings="{Binding Settings}"
                                             IsHitTestVisible="False" />
                <controls:TacticalScopeControl x:Name="ScopeControl"
                                               Picture="{Binding Picture}"
                                               Settings="{Binding Settings}"
                                               Airspaces="{Binding Airspaces}"
                                               Airports="{Binding Airports}"
                                               Navaids="{Binding Navaids}"
                                               ManualTargetMetadata="{Binding ManualTargetMetadata}" />
                <StackPanel Orientation="Vertical"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Margin="10">
                    <Button Content="Range +"
                            Width="88"
                            Margin="0,0,0,6"
                            Command="{Binding IncreaseRangeCommand}" />
                    <Button Content="Range -"
                            Width="88"
                            Command="{Binding DecreaseRangeCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <Border x:Name="SettingsBorder"
                Grid.Row="1"
                Grid.Column="1"
                Padding="10"
                Background="#102028"
                BorderBrush="#355A56"
                BorderThickness="1">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ShowSettings}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Settings"
                               FontFamily="Consolas"
                               Foreground="#9AFAD7"
                               FontSize="16"
                               Margin="0,0,0,8" />

                    <GroupBox Header="Display" Foreground="#9AFAD7" Margin="0,0,0,8" Padding="8">
                        <StackPanel>
                            <UniformGrid Columns="2" Rows="3">
                                <Button Content="N/HDG" Margin="4" Command="{Binding ToggleOrientationCommand}" />
                                <Button Content="{Binding DeclutterToggleText}" Margin="4" Command="{Binding ToggleDeclutterCommand}" />
                                <Button Content="Labels" Margin="4" Command="{Binding ToggleLabelsCommand}" />
                                <Button Content="{Binding TrailsToggleText}" Margin="4" Command="{Binding ToggleTrailsCommand}" />
                                <Button Content="{Binding MapToggleText}" Margin="4" Command="{Binding ToggleMapCommand}" />
                                <Button Content="{Binding AirspaceToggleText}" Margin="4" Command="{Binding ToggleAirspaceCommand}" />
                            </UniformGrid>
                            <TextBlock Text="{Binding MapOpacityText}"
                                       Foreground="#7CB9A9"
                                       Margin="4,8,4,0" />
                            <Slider Minimum="0"
                                    Maximum="100"
                                    TickFrequency="10"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding MapOpacityPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Margin="4,2,4,0" />
                            <Button Content="{Binding AirportsToggleText}"
                                    Margin="4,8,4,0"
                                    Command="{Binding ToggleAirportsCommand}" />
                            <TextBlock Text="{Binding AirportOpacityText}"
                                       Foreground="#7CB9A9"
                                       Margin="4,8,4,0" />
                            <Slider Minimum="0"
                                    Maximum="100"
                                    TickFrequency="10"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding AirportOpacityPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Margin="4,2,4,0" />
                            <TextBlock Text="{Binding AirportText}"
                                       Foreground="#7CB9A9"
                                       Margin="4,2,4,0" />
                            <Button Content="{Binding NavaidsToggleText}"
                                    Margin="4,8,4,0"
                                    Command="{Binding ToggleNavaidsCommand}" />
                            <TextBlock Text="{Binding NavaidOpacityText}"
                                       Foreground="#7CB9A9"
                                       Margin="4,8,4,0" />
                            <Slider Minimum="0"
                                    Maximum="100"
                                    TickFrequency="10"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding NavaidOpacityPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Margin="4,2,4,0" />
                            <TextBlock Text="{Binding NavaidText}"
                                       Foreground="#7CB9A9"
                                       Margin="4,2,4,0" />
                            <TextBlock Text="{Binding MapLabelBackgroundOpacityText}"
                                       Foreground="#7CB9A9"
                                       Margin="4,8,4,0" />
                            <Slider Minimum="0"
                                    Maximum="100"
                                    TickFrequency="10"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding MapLabelBackgroundOpacityPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Margin="4,2,4,0" />
                            <TextBlock Text="Minimum tracked altitude (ft)"
                                       Foreground="#7CB9A9"
                                       Margin="4,8,4,0" />
                            <TextBox Text="{Binding MinTrackedAltitudeFtText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Targets below this altitude are hidden"
                                     Margin="4,4,4,0" />
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Data Source" Foreground="#9AFAD7" Margin="0,0,0,8" Padding="8">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <ComboBox Width="150"
                                          ItemsSource="{Binding AvailableDataSources}"
                                          SelectedItem="{Binding SelectedDataSource}" />
                                <Button Content="Apply Source"
                                        Margin="8,0,0,0"
                                        Command="{Binding ApplyDataSourceCommand}" />
                            </StackPanel>
                            <TextBlock Text="{Binding SourceText}" Foreground="#9AFAD7" Margin="0,4,0,0" />
                            <StackPanel Margin="0,8,0,0">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ShowMsfsSettings}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="MSFS uses bundled SimConnect. If the connection fails, the app opens a diagnostic selection for MSFS exe or SimConnect DLL."
                                           Foreground="#7CB9A9"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Margin="0,8,0,0">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ShowXPlane12Settings}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="X-Plane 12 API URL" Foreground="#7CB9A9" />
                                <TextBox Text="{Binding XPlane12ApiBaseUrlText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Default: http://localhost:8086/"
                                         Margin="0,4,0,0" />
                                <TextBlock Text="Default: http://localhost:8086/"
                                           Foreground="#7CB9A9"
                                           Margin="0,2,0,0" />
                            </StackPanel>
                            <StackPanel Margin="0,8,0,0">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ShowXPlaneLegacySettings}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="Xplane Legacy uses XPUIPC from X-Plane\Resources\plugins."
                                           Foreground="#7CB9A9"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="V-LARA Airspace" Foreground="#9AFAD7" Margin="0,0,0,8" Padding="8">
                        <StackPanel>
                            <TextBlock Text="{Binding AirspaceText}" Foreground="#9AFAD7" />
                            <TextBlock Text="{Binding AirspaceOpacityText}" Foreground="#7CB9A9" Margin="0,6,0,0" />
                            <Slider Minimum="10"
                                    Maximum="100"
                                    TickFrequency="10"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding AirspaceOpacityPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Margin="0,2,0,0" />
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Bullseye" Foreground="#9AFAD7" Margin="0,0,0,8" Padding="8">
                        <StackPanel>
                            <UniformGrid Columns="2" Rows="2">
                                <Grid Margin="4">
                                    <TextBox x:Name="BullseyeLatitudeBox"
                                             Text="{Binding BullseyeLatitudeText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="Latitude, decimal degrees" />
                                    <TextBlock Text="N60.3172"
                                               Foreground="#778C8A"
                                               Margin="6,2,0,0"
                                               IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text, ElementName=BullseyeLatitudeBox}" Value="">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                                <Grid Margin="4">
                                    <TextBox x:Name="BullseyeLongitudeBox"
                                             Text="{Binding BullseyeLongitudeText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="Longitude, decimal degrees" />
                                    <TextBlock Text="E024.9633"
                                               Foreground="#778C8A"
                                               Margin="6,2,0,0"
                                               IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text, ElementName=BullseyeLongitudeBox}" Value="">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                                <Button Content="Set Bullseye"
                                        Command="{Binding ApplyBullseyeCommand}"
                                        Margin="4" />
                                <Button Content="Clear Bullseye"
                                        Command="{Binding ClearBullseyeCommand}"
                                        Margin="4" />
                            </UniformGrid>
                            <TextBlock Text="{Binding BullseyeText}" Foreground="#9AFAD7" Margin="0,4,0,0" />
                        </StackPanel>
                    </GroupBox>

                    <Button Content="Save Settings"
                            Command="{Binding SaveSettingsCommand}"
                            Margin="0,0,0,8" />

                    <Expander Header="Debug" Foreground="#7CB9A9" Margin="0,0,0,4">
                        <StackPanel Margin="0,8,0,0">
                            <CheckBox Content="Enable datasource debug log"
                                      IsChecked="{Binding DataSourceDebugLoggingEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Foreground="#9AFAD7" />
                            <Button Content="Open Debug Log Folder"
                                    Command="{Binding OpenDebugLogFolderCommand}"
                                    Margin="0,8,0,0" />
                            <TextBlock Text="Writes MSFS/XPlane feed diagnostics to config/logs/data-source-debug.log"
                                       Foreground="#7CB9A9"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0" />
                            <TextBlock Text="Range/alt/category filters can be edited in display.json."
                                       Foreground="#7CB9A9"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,0" />
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Margin="0,10,0,0"
                Padding="8"
                Background="#102028"
                BorderBrush="#355A56"
                BorderThickness="1">
            <DockPanel>
                <TextBlock Text="{Binding ConnectionText}" Foreground="#9AFAD7" Margin="0,0,16,0" />
                <TextBlock Text="{Binding TrafficText}" Foreground="#9AFAD7" Margin="0,0,16,0" />
                <TextBlock Text="{Binding SimulatorStatusLabel}" Foreground="#7CB9A9" Margin="0,0,4,0" />
                <TextBlock Text="{Binding SimConnectText}" Foreground="#9AFAD7" Margin="0,0,16,0" />
                <TextBlock Text="Simulator Use Only" Foreground="#F7C873" Margin="0,0,16,0" />
                <TextBlock Text="Refresh:" Foreground="#7CB9A9" Margin="0,0,4,0" />
                <TextBlock Text="{Binding RefreshRateText}" Foreground="#9AFAD7" Margin="0,0,16,0" />
                <TextBlock Text="{Binding SourceText}" Foreground="#9AFAD7" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
