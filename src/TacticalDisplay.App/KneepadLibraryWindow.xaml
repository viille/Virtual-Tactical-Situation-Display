<Window x:Class="TacticalDisplay.App.KneepadLibraryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Cloud Kneepad" Width="900" Height="680" WindowStartupLocation="CenterOwner" Background="#102028">
    <Grid Margin="10"><Grid.ColumnDefinitions><ColumnDefinition Width="260"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
        <ListBox x:Name="Pages" DisplayMemberPath="Title" SelectionChanged="OnPageChanged" Background="#172A33" Foreground="#D9F2EC">
            <ListBox.GroupStyle><GroupStyle><GroupStyle.HeaderTemplate><DataTemplate><TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="#9AFAD7" Margin="4,8,4,2"/></DataTemplate></GroupStyle.HeaderTemplate></GroupStyle></ListBox.GroupStyle>
        </ListBox>
        <wv2:WebView2 x:Name="Viewer" Grid.Column="1" Margin="10,0,0,0"/>
    </Grid>
</Window>
